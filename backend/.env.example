# Backend environment variables (copy to backend/.env for local development)

# development | production — gates /docs, /redoc, /openapi.json visibility
ENVIRONMENT=development

# JSON list of origins allowed by CORS. Use ["*"] for fully open dev.
ALLOWED_ORIGINS=["http://localhost:5173"]

# slowapi rate limit, applied per client IP on /query/build
RATE_LIMIT=60/minute
