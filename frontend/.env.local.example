# Frontend environment variables (copy to frontend/.env.local for local development)
# All vars must be prefixed with VITE_ to be exposed to the browser.

# Base URL the API client prefixes onto every request. Defaults to Vite's BASE_URL
# (`/querybuilder/`), which is correct when the frontend is served from the same
# origin as the API (dev proxy or production Nginx).
# Override only when calling a remote backend directly:
# VITE_API_BASE_URL=https://api.example.com/
