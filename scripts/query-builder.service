[Unit]
Description=Query Builder – FastAPI/uvicorn backend
After=network.target

[Service]
WorkingDirectory=/srv/query-builder/backend
Environment="PATH=%h/.local/bin:/usr/bin:/bin"
ExecStart=%h/.local/bin/uv run uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
